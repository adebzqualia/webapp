# API
APP_NAME=POPS Control Center
APP_ENV=development
API_PREFIX=/api
AUTH_API_KEY=
DEFAULT_ORGANIZATION=demo
DEFAULT_USER=demo-user
DATABASE_URL=postgresql+psycopg://pops:pops@db:5432/pops
STORAGE_ROOT=/app/data/storage
MAX_UPLOAD_SIZE_MB=50
MAX_ZIP_UNCOMPRESSED_MB=250
MAX_ZIP_COMPRESSION_RATIO=100
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Web
VITE_API_URL=http://localhost:8000/api
VITE_USE_MOCKS=false

# PostgreSQL (Docker development)
POSTGRES_DB=pops
POSTGRES_USER=pops
POSTGRES_PASSWORD=pops
